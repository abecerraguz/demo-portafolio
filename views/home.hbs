<!-- ════════════════════════════ HERO ════════════════════════════ -->
<section id="hero" class="hero-section d-flex align-items-center">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                {{#if presentation}}
                    <p class="hero-greeting text-primary fw-semibold mb-1 animate-fade-up">
                        {{presentation.greeting}}
                    </p>
                    <h1 class="hero-name display-3 fw-bold text-white mb-2 animate-fade-up delay-1">
                        {{presentation.name}}
                    </h1>
                    <h2 class="hero-title h3 text-light mb-3 animate-fade-up delay-2">
                        {{presentation.title}}
                    </h2>
                    {{#if presentation.subtitle}}
                    <p class="hero-subtitle text-secondary fs-5 mb-4 animate-fade-up delay-3">
                        {{presentation.subtitle}}
                    </p>
                    {{/if}}
                    {{#if presentation.description}}
                    <p class="text-light opacity-75 mb-4 animate-fade-up delay-3" style="max-width:580px">
                        {{presentation.description}}
                    </p>
                    {{/if}}
                    <div class="d-flex gap-3 animate-fade-up delay-4">
                        <a href="{{presentation.cta_url}}" class="btn btn-primary btn-lg px-4">
                            {{presentation.cta_text}}
                            <i class="bi bi-arrow-down ms-2"></i>
                        </a>
                        {{#if aboutMe.github_url}}
                        <a href="{{aboutMe.github_url}}" class="btn btn-outline-light btn-lg px-4" target="_blank" rel="noopener">
                            <i class="bi bi-github me-2"></i>GitHub
                        </a>
                        {{/if}}
                    </div>
                {{else}}
                    <h1 class="display-3 fw-bold text-white">Bienvenido a mi portafolio</h1>
                    <p class="text-light">Configura tu perfil desde el <a href="/admin" class="text-primary">panel admin</a>.</p>
                {{/if}}
            </div>
        </div>
    </div>
    <div class="hero-scroll-indicator">
        <a href="#about"><i class="bi bi-chevron-double-down text-primary fs-3 bounce"></i></a>
    </div>
</section>

<!-- ════════════════════════════ SOBRE MÍ ════════════════════════════ -->
<section id="about" class="py-5 bg-white">
    <div class="container py-4">
        <div class="section-header text-center mb-5">
            <h2 class="fw-bold">{{#if aboutMe}}{{aboutMe.title}}{{else}}Sobre mí{{/if}}</h2>
            <div class="section-divider mx-auto"></div>
        </div>

        {{#if aboutMe}}
        <div class="row align-items-center g-5">
            <div class="col-lg-4 text-center">
                {{#if aboutMe.profile_image}}
                <img src="{{aboutMe.profile_image}}" alt="Foto de perfil"
                     class="profile-photo rounded-circle shadow mb-3">
                {{else}}
                <div class="profile-placeholder mx-auto rounded-circle bg-primary d-flex align-items-center justify-content-center">
                    <i class="bi bi-person text-white" style="font-size:5rem;"></i>
                </div>
                {{/if}}

                <!-- Social links -->
                <div class="d-flex justify-content-center gap-3 mt-3">
                    {{#if aboutMe.github_url}}
                    <a href="{{aboutMe.github_url}}" class="btn btn-outline-dark btn-sm" target="_blank" rel="noopener">
                        <i class="bi bi-github"></i>
                    </a>
                    {{/if}}
                    {{#if aboutMe.linkedin_url}}
                    <a href="{{aboutMe.linkedin_url}}" class="btn btn-outline-primary btn-sm" target="_blank" rel="noopener">
                        <i class="bi bi-linkedin"></i>
                    </a>
                    {{/if}}
                    {{#if aboutMe.email}}
                    <a href="mailto:{{aboutMe.email}}" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-envelope"></i>
                    </a>
                    {{/if}}
                </div>
                {{#if aboutMe.location}}
                <p class="text-muted mt-2 small"><i class="bi bi-geo-alt me-1"></i>{{aboutMe.location}}</p>
                {{/if}}
            </div>

            <div class="col-lg-8">
                <p class="lead text-secondary lh-lg">{{aboutMe.content}}</p>

                {{#if aboutMe.skills.length}}
                <h5 class="fw-semibold mt-4 mb-3">Tecnologías & Habilidades</h5>
                <div class="d-flex flex-wrap gap-2">
                    {{#each aboutMe.skills}}
                    <span class="badge skill-badge">{{this}}</span>
                    {{/each}}
                </div>
                {{/if}}
            </div>
        </div>
        {{else}}
        <p class="text-center text-muted">Aún no hay información. Configúrala desde el <a href="/admin">panel admin</a>.</p>
        {{/if}}
    </div>
</section>

<!-- ════════════════════════════ PROYECTOS ════════════════════════════ -->
<section id="projects" class="py-5 bg-light">
    <div class="container py-4">
        <div class="section-header text-center mb-5">
            <h2 class="fw-bold">Proyectos</h2>
            <div class="section-divider mx-auto"></div>
        </div>

        {{#if projects.length}}
        <div class="row g-4">
            {{#each projects}}
            <div class="col-md-6 col-xl-4">
                <div class="card project-card h-100 border-0 shadow-sm">
                    {{#if this.image_url}}
                    <img src="{{this.image_url}}" class="card-img-top project-img" alt="{{this.title}}">
                    {{else}}
                    <div class="project-img-placeholder d-flex align-items-center justify-content-center bg-secondary bg-opacity-10">
                        <i class="bi bi-image text-muted" style="font-size:3rem;"></i>
                    </div>
                    {{/if}}
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">{{this.title}}</h5>
                            {{#if this.is_featured}}
                            <span class="badge bg-warning text-dark ms-2">Destacado</span>
                            {{/if}}
                        </div>
                        {{#if this.description}}
                        <p class="card-text text-muted small flex-grow-1">{{truncate this.description 120}}</p>
                        {{/if}}

                        {{#if this.tech_stack.length}}
                        <div class="d-flex flex-wrap gap-1 my-2">
                            {{#each this.tech_stack}}
                            <span class="badge bg-dark bg-opacity-75 small">{{this}}</span>
                            {{/each}}
                        </div>
                        {{/if}}

                        <div class="d-flex gap-2 mt-auto pt-2">
                            {{#if this.github_url}}
                            <a href="{{this.github_url}}" class="btn btn-sm btn-outline-dark" target="_blank" rel="noopener">
                                <i class="bi bi-github me-1"></i>Código
                            </a>
                            {{/if}}
                            {{#if this.demo_url}}
                            <a href="{{this.demo_url}}" class="btn btn-sm btn-primary" target="_blank" rel="noopener">
                                <i class="bi bi-box-arrow-up-right me-1"></i>Demo
                            </a>
                            {{/if}}
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
        <p class="text-center text-muted">Aún no hay proyectos. Agrégalos desde el <a href="/admin">panel admin</a>.</p>
        {{/if}}
    </div>
</section>

<!-- ════════════════════════════ EDUCACIÓN ════════════════════════════ -->
<section id="education" class="py-5 bg-white">
    <div class="container py-4">
        <div class="section-header text-center mb-5">
            <h2 class="fw-bold">Educación</h2>
            <div class="section-divider mx-auto"></div>
        </div>

        {{#if education.length}}
        <div class="row g-4">
            {{#each education}}
            <div class="col-md-6">
                <div class="card edu-card h-100 border-0 shadow-sm p-1">
                    <div class="card-body d-flex gap-3">
                        <div class="edu-icon bg-primary bg-opacity-10 rounded-3 p-3 d-flex align-items-center justify-content-center flex-shrink-0">
                            {{#if this.logo_url}}
                            <img src="{{this.logo_url}}" alt="{{this.institution}}" style="width:40px;height:40px;object-fit:contain;">
                            {{else}}
                            <i class="bi bi-mortarboard text-primary fs-3"></i>
                            {{/if}}
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">{{this.degree}}</h5>
                            <p class="text-primary fw-semibold mb-1">{{this.institution}}</p>
                            {{#if this.field_of_study}}
                            <p class="text-muted small mb-1">{{this.field_of_study}}</p>
                            {{/if}}
                            <p class="text-muted small mb-2">
                                <i class="bi bi-calendar me-1"></i>
                                {{#if this.start_year}}{{this.start_year}}{{/if}}
                                {{#if this.end_year}} — {{this.end_year}}{{/if}}
                                {{#if this.is_current}} — <span class="badge bg-success">En curso</span>{{/if}}
                            </p>
                            {{#if this.description}}
                            <p class="text-secondary small mb-0">{{this.description}}</p>
                            {{/if}}
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
        <p class="text-center text-muted">Aún no hay registros educativos. Agrégalos desde el <a href="/admin">panel admin</a>.</p>
        {{/if}}
    </div>
</section>

<!-- ════════════════════════════ CONTACTO ════════════════════════════ -->
<section id="contact" class="py-5 bg-dark text-white">
    <div class="container py-4 text-center">
        <h2 class="fw-bold mb-3">¿Trabajamos juntos?</h2>
        <p class="text-secondary mb-4 fs-5">Estoy disponible para proyectos freelance y oportunidades laborales.</p>
        {{#if aboutMe.email}}
        <a href="mailto:{{aboutMe.email}}" class="btn btn-primary btn-lg px-5">
            <i class="bi bi-envelope me-2"></i>{{aboutMe.email}}
        </a>
        {{/if}}
    </div>
</section>
