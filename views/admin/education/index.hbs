<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="bi bi-mortarboard me-2 text-warning"></i>Educación
    </h5>
    <a href="/admin/education/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Nueva entrada
    </a>
</div>

{{#if education.length}}
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Institución</th>
                        <th>Título / Carrera</th>
                        <th>Período</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each education}}
                    <tr>
                        <td class="fw-semibold">{{this.institution}}</td>
                        <td>
                            {{this.degree}}
                            {{#if this.field_of_study}}
                            <br><small class="text-muted">{{this.field_of_study}}</small>
                            {{/if}}
                        </td>
                        <td class="text-muted small">
                            {{#if this.start_year}}{{this.start_year}}{{/if}}
                            {{#if this.end_year}} — {{this.end_year}}{{/if}}
                            {{#if this.is_current}}<span class="badge bg-success ms-1">En curso</span>{{/if}}
                        </td>
                        <td>
                            {{#if this.is_active}}
                            <span class="badge bg-success-subtle text-success">Activo</span>
                            {{else}}
                            <span class="badge bg-secondary-subtle text-secondary">Inactivo</span>
                            {{/if}}
                        </td>
                        <td class="text-end">
                            <a href="/admin/education/{{this.id}}/edit" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form action="/admin/education/{{this.id}}/delete" method="POST" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar este registro?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>
{{else}}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-journal-x text-muted" style="font-size:3rem;"></i>
        <p class="text-muted mt-3 mb-4">Aún no hay registros educativos.</p>
        <a href="/admin/education/new" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Agregar primer registro
        </a>
    </div>
</div>
{{/if}}
