<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="bi bi-folder2-open me-2 text-info"></i>Proyectos
    </h5>
    <a href="/admin/projects/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Nuevo proyecto
    </a>
</div>

{{#if projects.length}}
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                        <tr>
                            <th>Imagen</th>
                            <th>Proyecto</th>
                            <th>Tecnologías</th>
                            <th>Orden</th>
                            <th>Estado</th>
                            <th>Destacado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                </thead>
                <tbody>
                    {{#each projects}}
                    <tr>
                        <td>
                            {{#if this.image_url}}
                                <img src="{{this.image_url}}" alt="Imagen proyecto" style="width:48px;max-height:48px;object-fit:cover;border-radius:6px;">
                            {{else}}
                                <span class="text-muted">—</span>
                            {{/if}}
                        </td>
                        <td>
                            <div class="fw-semibold">{{this.title}}</div>
                            {{#if this.description}}
                            <small class="text-muted">{{truncate this.description 60}}</small>
                            {{/if}}
                        </td>
                        <td>
                            {{#each this.tech_stack}}
                            <span class="badge bg-secondary bg-opacity-25 text-dark me-1">{{this}}</span>
                            {{/each}}
                        </td>
                        <td><span class="badge bg-light text-dark border">{{this.display_order}}</span></td>
                        <td>
                            {{#if this.is_active}}
                            <span class="badge bg-success-subtle text-success">Activo</span>
                            {{else}}
                            <span class="badge bg-secondary-subtle text-secondary">Inactivo</span>
                            {{/if}}
                        </td>
                        <td>
                            {{#if this.is_featured}}
                            <i class="bi bi-star-fill text-warning"></i>
                            {{else}}
                            <i class="bi bi-star text-muted"></i>
                            {{/if}}
                        </td>
                        <td class="text-end">
                            <a href="/admin/projects/{{this.id}}/edit" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form action="/admin/projects/{{this.id}}/delete" method="POST" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar este proyecto? Esta acción no se puede deshacer.')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>
{{else}}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-folder-x text-muted" style="font-size:3rem;"></i>
        <p class="text-muted mt-3 mb-4">Aún no hay proyectos registrados.</p>
        <a href="/admin/projects/new" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Agregar primer proyecto
        </a>
    </div>
</div>
{{/if}}
