# Variables de entorno — Portfolio App
# Copia este archivo como .env y completa los valores

# ─── Servidor ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de datos (desarrollo local) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portafolio_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ─── Base de datos (Railway — se asigna automáticamente) ────────────────────
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_por_uno_seguro_de_64_caracteres_minimo
JWT_EXPIRES_IN=24h

# ─── Admin por defecto (primer deploy) ──────────────────────────────────────
ADMIN_EMAIL=admin@portafolio.com
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Administrador
