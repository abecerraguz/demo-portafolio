<div class="card border-0 shadow-sm" style="max-width:720px">
    <div class="card-header bg-transparent border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0">
            <i class="bi bi-pencil-square me-2 text-primary"></i>Editar Proyecto
        </h5>
        <a href="/admin/projects" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>

    <div class="card-body p-4">
        <form action="/admin/projects/{{project.id}}" method="POST" novalidate>

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Título del proyecto <span class="text-danger">*</span></label>
                    <input type="text" name="title" class="form-control"
                           value="{{project.title}}" required maxlength="200">
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Descripción</label>
                    <textarea name="description" class="form-control" rows="4">{{project.description}}</textarea>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Tecnologías</label>
                    <input type="text" name="tech_stack" class="form-control"
                           value="{{project.tech_stack_text}}"
                           placeholder="ej: React, Node.js, PostgreSQL">
                    <div class="form-text">Separa cada tecnología con una coma.</div>
                </div>

                <div class="col-12">
                        <label class="form-label fw-semibold">Imagen del proyecto</label>
                        <input type="file" id="image_upload" accept="image/*" class="form-control mb-2">
                        <input type="hidden" name="image_url" id="image_url" value="{{project.image_url}}">
                        <div class="form-text">Puedes subir una imagen (JPG, PNG, GIF, WEBP, máx. 5MB) o pegar una URL.</div>
                        <div id="upload_status" class="small text-success"></div>
                        {{#if project.image_url}}
                            <img src="{{project.image_url}}" alt="Imagen actual" style="max-width:120px;max-height:80px;object-fit:cover;border-radius:6px;display:block;margin-top:8px;">
                        {{/if}}
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold"><i class="bi bi-github me-1"></i>GitHub URL</label>
                    <input type="url" name="github_url" class="form-control"
                           value="{{project.github_url}}"
                           placeholder="https://github.com/usuario/repo">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold"><i class="bi bi-box-arrow-up-right me-1"></i>Demo URL</label>
                    <input type="url" name="demo_url" class="form-control"
                           value="{{project.demo_url}}"
                           placeholder="https://mi-proyecto.com">
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Orden de visualización</label>
                    <input type="number" name="display_order" class="form-control"
                           value="{{project.display_order}}" min="0">
                </div>

                <div class="col-md-4 d-flex align-items-end pb-1">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="is_featured" id="is_featured"
                               {{#if project.is_featured}}checked{{/if}}>
                        <label class="form-check-label fw-semibold" for="is_featured">
                            <i class="bi bi-star me-1"></i>Destacado
                        </label>
                    </div>
                </div>

                <div class="col-md-4 d-flex align-items-end pb-1">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="is_active" id="is_active"
                               {{#if project.is_active}}checked{{/if}}>
                        <label class="form-check-label fw-semibold" for="is_active">
                            <i class="bi bi-eye me-1"></i>Visible
                        </label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save me-2"></i>Guardar cambios
                </button>
                <a href="/admin/projects" class="btn btn-outline-secondary">Cancelar</a>
                <form action="/admin/projects/{{project.id}}/delete" method="POST" class="ms-auto"
                      onsubmit="return confirm('¿Eliminar este proyecto? Esta acción no se puede deshacer.')">
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                </form>
            </div>
        </form>
        <script>
        document.addEventListener('DOMContentLoaded', function() {
            const fileInput = document.getElementById('image_upload');
            const imageUrlInput = document.getElementById('image_url');
            const statusDiv = document.getElementById('upload_status');
            fileInput?.addEventListener('change', async function(e) {
                e.preventDefault();
                e.stopPropagation(); // Refuerzo: nunca submit
                const file = fileInput.files[0];
                if (!file) return false;
                statusDiv.textContent = 'Subiendo imagen...';
                const formData = new FormData();
                formData.append('image', file);
                try {
                    const res = await fetch('/admin/projects/upload', {
                        method: 'POST',
                        body: formData
                    });
                    const data = await res.json();
                    if (data.url) {
                        imageUrlInput.value = data.url;
                        statusDiv.textContent = 'Imagen subida correctamente.';
                    } else {
                        statusDiv.textContent = data.error || 'Error al subir imagen.';
                    }
                } catch (err) {
                    statusDiv.textContent = 'Error al subir imagen.';
                }
                return false;
            });
        });
        </script>
    </div>
</div>
