<div class="row g-4 mb-4">
    <!-- Presentación -->
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="icon-box bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-person-badge text-primary fs-4"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0 fw-bold">Presentación</h6>
                        <small class="text-muted">Mensaje de bienvenida</small>
                    </div>
                </div>
                {{#if presentation}}
                <p class="text-muted small flex-grow-1 mb-3">
                    <strong>{{presentation.name}}</strong><br>
                    {{truncate presentation.title 60}}
                </p>
                <span class="badge bg-success-subtle text-success mb-2">
                    <i class="bi bi-check-circle me-1"></i>Configurado
                </span>
                {{else}}
                <p class="text-muted small flex-grow-1 mb-3">Sin configurar</p>
                <span class="badge bg-warning-subtle text-warning mb-2">
                    <i class="bi bi-exclamation-circle me-1"></i>Pendiente
                </span>
                {{/if}}
                <a href="/admin/presentation/edit" class="btn btn-sm btn-outline-primary mt-auto">
                    <i class="bi bi-pencil me-1"></i>Editar
                </a>
            </div>
        </div>
    </div>

    <!-- Sobre mí -->
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="icon-box bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-person-circle text-success fs-4"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0 fw-bold">Sobre mí</h6>
                        <small class="text-muted">Tu perfil</small>
                    </div>
                </div>
                {{#if aboutMe}}
                <p class="text-muted small flex-grow-1 mb-3">{{truncate aboutMe.content 80}}</p>
                <span class="badge bg-success-subtle text-success mb-2">
                    <i class="bi bi-check-circle me-1"></i>Configurado
                </span>
                {{else}}
                <p class="text-muted small flex-grow-1 mb-3">Sin configurar</p>
                <span class="badge bg-warning-subtle text-warning mb-2">
                    <i class="bi bi-exclamation-circle me-1"></i>Pendiente
                </span>
                {{/if}}
                <a href="/admin/aboutme/edit" class="btn btn-sm btn-outline-success mt-auto">
                    <i class="bi bi-pencil me-1"></i>Editar
                </a>
            </div>
        </div>
    </div>

    <!-- Proyectos -->
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="icon-box bg-info bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-folder2-open text-info fs-4"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0 fw-bold">Proyectos</h6>
                        <small class="text-muted">Tu portafolio</small>
                    </div>
                </div>
                <p class="display-6 fw-bold text-info mb-1">{{projectsCount}}</p>
                <p class="text-muted small flex-grow-1 mb-3">proyectos registrados</p>
                <a href="/admin/projects" class="btn btn-sm btn-outline-info mt-auto">
                    <i class="bi bi-list me-1"></i>Administrar
                </a>
            </div>
        </div>
    </div>

    <!-- Educación -->
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="icon-box bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-mortarboard text-warning fs-4"></i>
                    </div>
                    <div>
                        <h6 class="card-title mb-0 fw-bold">Educación</h6>
                        <small class="text-muted">Tu trayectoria</small>
                    </div>
                </div>
                <p class="display-6 fw-bold text-warning mb-1">{{educationCount}}</p>
                <p class="text-muted small flex-grow-1 mb-3">registros de educación</p>
                <a href="/admin/education" class="btn btn-sm btn-outline-warning mt-auto">
                    <i class="bi bi-list me-1"></i>Administrar
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Quick actions -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-0 pt-4 pb-0">
        <h5 class="fw-bold">Acciones rápidas</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-auto">
                <a href="/admin/projects/new" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Nuevo proyecto
                </a>
            </div>
            <div class="col-auto">
                <a href="/admin/education/new" class="btn btn-outline-secondary">
                    <i class="bi bi-plus-circle me-2"></i>Nueva educación
                </a>
            </div>
            <div class="col-auto">
                <a href="/" target="_blank" class="btn btn-outline-dark">
                    <i class="bi bi-eye me-2"></i>Ver portafolio
                </a>
            </div>
        </div>
    </div>
</div>
