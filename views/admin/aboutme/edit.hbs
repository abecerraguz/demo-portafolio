<div class="card border-0 shadow-sm" style="max-width:720px">
    <div class="card-header bg-transparent border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0">
            <i class="bi bi-person-circle me-2 text-success"></i>Editar Sobre mí
        </h5>
        <a href="/admin/dashboard" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Dashboard
        </a>
    </div>

    <div class="card-body p-4">
        <form action="/admin/aboutme/edit" method="POST" novalidate>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Título de sección</label>
                    <input type="text" name="title" class="form-control"
                           value="{{aboutMe.title}}" maxlength="150">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Ubicación</label>
                    <input type="text" name="location" class="form-control"
                           value="{{aboutMe.location}}" placeholder="ej: Santiago, Chile">
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Contenido / Descripción <span class="text-danger">*</span></label>
                    <textarea name="content" class="form-control" rows="5"
                              required>{{aboutMe.content}}</textarea>
                    <div class="form-text">Cuéntanos sobre ti, tu experiencia y pasiones.</div>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Habilidades & Tecnologías</label>
                    <input type="text" name="skills" class="form-control"
                           value="{{aboutMe.skills_text}}"
                           placeholder="ej: JavaScript, Node.js, React, PostgreSQL">
                    <div class="form-text">Separa cada habilidad con una coma.</div>
                </div>

                <div class="col-12">
                        <label class="form-label fw-semibold">Foto de perfil</label>
                        <input type="file" id="profile_image_upload" accept="image/*" class="form-control mb-2">
                        <input type="hidden" name="profile_image" id="profile_image" value="{{aboutMe.profile_image}}">
                        <div class="form-text">Puedes subir una imagen (JPG, PNG, GIF, WEBP, máx. 5MB) o pegar una URL.</div>
                        <div id="profile_upload_status" class="small text-success"></div>
                        {{#if aboutMe.profile_image}}
                            <img src="{{aboutMe.profile_image}}" alt="Foto actual" style="max-width:120px;max-height:80px;object-fit:cover;border-radius:6px;display:block;margin-top:8px;">
                        {{/if}}
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-github me-1"></i>GitHub URL
                    </label>
                    <input type="url" name="github_url" class="form-control"
                           value="{{aboutMe.github_url}}"
                           placeholder="https://github.com/usuario">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-linkedin me-1"></i>LinkedIn URL
                    </label>
                    <input type="url" name="linkedin_url" class="form-control"
                           value="{{aboutMe.linkedin_url}}"
                           placeholder="https://linkedin.com/in/usuario">
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email de contacto</label>
                    <input type="email" name="email" class="form-control"
                           value="{{aboutMe.email}}"
                           placeholder="tu@email.com">
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success px-4">
                    <i class="bi bi-save me-2"></i>Guardar cambios
                </button>
                <a href="/admin/dashboard" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
        <script>
        document.addEventListener('DOMContentLoaded', function() {
            const fileInput = document.getElementById('profile_image_upload');
            const imageUrlInput = document.getElementById('profile_image');
            const statusDiv = document.getElementById('profile_upload_status');
            fileInput?.addEventListener('change', async function(e) {
                e.preventDefault();
                e.stopPropagation(); // Refuerzo: nunca submit
                const file = fileInput.files[0];
                if (!file) return false;
                statusDiv.textContent = 'Subiendo imagen...';
                const formData = new FormData();
                formData.append('image', file);
                try {
                    const res = await fetch('/admin/projects/upload', {
                        method: 'POST',
                        body: formData
                    });
                    const data = await res.json();
                    if (data.url) {
                        imageUrlInput.value = data.url;
                        statusDiv.textContent = 'Imagen subida correctamente.';
                    } else {
                        statusDiv.textContent = data.error || 'Error al subir imagen.';
                    }
                } catch (err) {
                    statusDiv.textContent = 'Error al subir imagen.';
                }
                return false;
            });
        });
        </script>
    </div>
</div>
