<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Custom Admin CSS -->
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body bg-light">

<div class="d-flex" id="admin-wrapper">

    <!-- Sidebar -->
    <nav class="sidebar bg-dark text-white d-flex flex-column p-0" id="sidebar">
        <div class="sidebar-header p-3 border-bottom border-secondary">
            <a href="/admin/dashboard" class="text-white text-decoration-none d-flex align-items-center gap-2">
                <i class="bi bi-code-slash fs-4"></i>
                <span class="fw-bold fs-5">Portfolio Admin</span>
            </a>
        </div>

        <ul class="nav flex-column flex-grow-1 p-2 mt-1">
            <li class="nav-item mb-1">
                <a href="/admin/dashboard" class="nav-link text-white sidebar-link">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item mb-1">
                <a href="/admin/presentation/edit" class="nav-link text-white sidebar-link">
                    <i class="bi bi-person-badge me-2"></i> Presentación
                </a>
            </li>
            <li class="nav-item mb-1">
                <a href="/admin/aboutme/edit" class="nav-link text-white sidebar-link">
                    <i class="bi bi-person-circle me-2"></i> Sobre mí
                </a>
            </li>
            <li class="nav-item mb-1">
                <a href="/admin/projects" class="nav-link text-white sidebar-link">
                    <i class="bi bi-folder2-open me-2"></i> Proyectos
                </a>
            </li>
            <li class="nav-item mb-1">
                <a href="/admin/education" class="nav-link text-white sidebar-link">
                    <i class="bi bi-mortarboard me-2"></i> Educación
                </a>
            </li>
        </ul>

        <div class="p-3 border-top border-secondary">
            <a href="/" class="text-secondary text-decoration-none small d-flex align-items-center gap-2 mb-2" target="_blank">
                <i class="bi bi-eye"></i> Ver portafolio
            </a>
            <form action="/admin/logout" method="POST">
                <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                    <i class="bi bi-box-arrow-left me-1"></i> Cerrar sesión
                </button>
            </form>
        </div>
    </nav>

    <!-- Contenido principal -->
    <div class="admin-content flex-grow-1">
        <!-- Top bar -->
        <header class="admin-topbar bg-white border-bottom px-4 py-3 d-flex justify-content-between align-items-center">
            <button class="btn btn-sm btn-outline-secondary d-md-none" id="sidebarToggle">
                <i class="bi bi-list fs-5"></i>
            </button>
            <h6 class="mb-0 fw-semibold text-muted">{{title}}</h6>
            {{#if adminUser}}
            <span class="badge bg-secondary">
                <i class="bi bi-person-fill me-1"></i>{{adminUser.name}}
            </span>
            {{/if}}
        </header>

        <!-- Flash messages -->
        {{> flash}}

        <!-- Page content -->
        <div class="p-4">
            {{{body}}}
        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/admin.js"></script>
</body>
</html>
